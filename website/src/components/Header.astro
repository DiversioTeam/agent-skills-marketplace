---
// Header.astro — Top navigation bar
export interface Props {
  currentNav?: "marketplace" | "docs" | "registry" | "community";
}

const { currentNav = "marketplace" } = Astro.props;

const navItems = [
  { label: "Marketplace", href: "/", key: "marketplace" },
  { label: "Documentation", href: "/docs", key: "docs" },
  { label: "Registry", href: "/registry", key: "registry" },
  { label: "Community", href: "/community", key: "community" },
];
---
<header class="header">
  <div class="header-inner">
    <div class="header-left">
      <a href="/" class="header-brand" aria-label="Agent Skills Marketplace Home">
        <img
          src="/diversio-logo.svg"
          alt="Diversio"
          class="header-brand-logo"
          width="116"
          height="20"
        />
        <span class="header-brand-divider" aria-hidden="true"></span>
        <span class="header-brand-product">Agent Skills Marketplace</span>
      </a>
      <nav class="header-nav" aria-label="Main navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`header-nav-link${item.key === currentNav ? " header-nav-link--active" : ""}`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
    <div class="header-right">
      <a href="https://github.com/DiversioTeam/agent-skills-marketplace" class="header-icon-btn" aria-label="GitHub Repository" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
      </a>
      <a href="/docs" class="btn btn-primary header-cta">
        Get Started
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    border-bottom: var(--border-hairline);
    height: var(--header-height);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-margin);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    height: 100%;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .header-brand-logo {
    display: block;
    width: auto;
    height: 1.125rem;
    flex-shrink: 0;
  }

  .header-brand-divider {
    width: 1px;
    align-self: stretch;
    min-height: 1rem;
    margin-block: 1px;
    background: var(--color-hairline-solid);
  }

  .header-brand-product {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-headline);
    font-weight: var(--weight-semibold);
    font-size: var(--text-body-md);
    line-height: 1;
    color: var(--color-primary);
    white-space: nowrap;
  }

  .header-nav {
    display: flex;
    align-items: stretch;
    height: 100%;
    gap: var(--space-md);
  }

  .header-nav-link {
    display: flex;
    align-items: center;
    padding: 0 var(--space-xs);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    height: 100%;
  }

  .header-nav-link:hover {
    color: var(--color-primary);
  }

  .header-nav-link--active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .header-icon-btn:hover {
    color: var(--color-primary);
    background: var(--color-surface-low);
  }

  .header-cta {
    margin-left: var(--space-xs);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .header-nav {
      display: none;
    }
    .header-cta {
      padding: var(--space-xs) var(--space-sm);
      font-size: var(--text-code-sm);
    }
    .header-inner {
      padding: 0 var(--space-md);
    }
    .header-icon-btn {
      display: none;
    }
    .header-brand-divider,
    .header-brand-product {
      display: none;
    }
  }

</style>
