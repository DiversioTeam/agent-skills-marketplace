---
// PageLayout.astro — Marketing/page layout: header + main + footer
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  socialTitle?: string;
  socialDescription?: string;
  socialImageAlt?: string;
  socialType?: "website" | "article";
  ogImageWidth?: number;
  ogImageHeight?: number;
  currentNav?: "marketplace" | "docs" | "registry" | "community";
}

const {
  title,
  description,
  ogImage,
  socialTitle,
  socialDescription,
  socialImageAlt,
  socialType,
  ogImageWidth,
  ogImageHeight,
  currentNav,
} = Astro.props;
---
<BaseLayout
  {title}
  {description}
  {ogImage}
  {socialTitle}
  {socialDescription}
  {socialImageAlt}
  {socialType}
  {ogImageWidth}
  {ogImageHeight}
>
  <Header currentNav={currentNav} />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
